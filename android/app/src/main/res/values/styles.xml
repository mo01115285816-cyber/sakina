<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- القاعدة #4: السماح بالامتداد خلف النوتش -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- القاعدة #4: السماح بالامتداد خلف النوتش -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- القاعدة #8: إزالة كاملة للشاشة الأولية (لا كريمي، لا أبيض، لا شيء قبل SplashScreen)
         windowDisablePreview = إلغاء نافذة المعاينة بالكامل
         windowIsTranslucent = النافذة شفافة
         windowBackground = transparent = لا خلفية ملونة -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <!-- القاعدة #8: إزالة كاملة للشاشة الأولية -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowDisablePreview">true</item>
        <!-- القاعدة #4: السماح بالامتداد خلف النوتش -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
