{
  "name": "sakina",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "npm run verify-fonts && npm run pack-fonts && vite build && esbuild src/server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "download-fonts": "node scripts/download-qcf-fonts.js",
    "pack-fonts": "node scripts/pack-qcf-fonts.js",
    "verify-fonts": "node scripts/verify-fonts.js",
    "fix-basmala": "node scripts/fix-basmala-codes.js",
    "prebuild": "npm run verify-fonts"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capgo/capacitor-zip": "^8.1.16",
    "@google/genai": "^2.10.0",
    "@types/leaflet": "^1.9.21",
    "adhan": "^4.4.4",
    "clsx": "2.1.1",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "localforage": "^1.10.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@types/express": "^5.0.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vite": "7.3.2"
  }
}
